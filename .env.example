# Databricks auth profile from ~/.databrickscfg
DATABRICKS_CONFIG_PROFILE=DEFAULT

# SQL warehouse ID for system tables queries (cost, query history, audit, Delta health)
# Required for: get_job_cost, get_query_history, get_cluster_utilization, get_audit_events,
#               get_table_health, get_table_history, get_predictive_optimization
# Find yours: Databricks UI → SQL Warehouses → select warehouse → copy ID from URL
DATABRICKS_WAREHOUSE_ID=
